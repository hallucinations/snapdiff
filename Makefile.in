# Generated by ./configure — do not edit directly
CC      = @CC@
PREFIX  = @PREFIX@
CFLAGS  = -Wall -Wextra -O2 -Isrc @EXTRA_CFLAGS@

BINDIR  = $(PREFIX)/bin
MANDIR  = $(PREFIX)/share/man/man1

SRCS    = src/main.c src/hash.c src/snapshot.c src/diff.c
OBJS    = $(SRCS:.c=.o)
BIN     = snapdiff

# ---- Default target ------------------------------------------------
all: $(BIN)

$(BIN): $(OBJS)
	$(CC) $(CFLAGS) -o $@ $^

src/%.o: src/%.c
	$(CC) $(CFLAGS) -c $< -o $@

# ---- Dependencies --------------------------------------------------
src/main.o:     src/main.c     src/snapshot.h src/diff.h
src/snapshot.o: src/snapshot.c src/snapshot.h src/hash.h
src/diff.o:     src/diff.c     src/diff.h     src/snapshot.h
src/hash.o:     src/hash.c     src/hash.h

# ---- Install / Uninstall -------------------------------------------
install: $(BIN)
	install -d $(DESTDIR)$(BINDIR)
	install -m 755 $(BIN) $(DESTDIR)$(BINDIR)/$(BIN)
	@echo "Installed $(BIN) to $(DESTDIR)$(BINDIR)"

uninstall:
	rm -f $(DESTDIR)$(BINDIR)/$(BIN)
	@echo "Removed $(DESTDIR)$(BINDIR)/$(BIN)"

# ---- Housekeeping --------------------------------------------------
clean:
	rm -f $(OBJS) $(BIN)

distclean: clean
	rm -f Makefile

.PHONY: all install uninstall clean distclean
