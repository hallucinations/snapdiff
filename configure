#!/bin/sh
# configure script for snapdiff

set -e

CC=${CC:-gcc}
PREFIX=${PREFIX:-/usr/local}
VERSION=$(cat VERSION)

# ---- Parse arguments -----------------------------------------------
for arg in "$@"; do
    case "$arg" in
        --prefix=*)   PREFIX="${arg#*=}" ;;
        --cc=*)       CC="${arg#*=}" ;;
        --help|-h)
            cat <<EOF
Usage: ./configure [OPTIONS]

Options:
  --prefix=DIR   Install files in DIR [/usr/local]
  --cc=CC        C compiler to use [gcc]
  --help         Show this help message

Environment variables:
  CC             C compiler (overrides --cc)
  CFLAGS         Extra compiler flags (e.g. -I/path/to/openssl/include)
  LDFLAGS        Extra linker flags   (e.g. -L/path/to/openssl/lib)
EOF
            exit 0
            ;;
        *)
            echo "configure: unknown option '$arg' (try --help)" >&2
            exit 1
            ;;
    esac
done

# ---- Check for tools -----------------------------------------------
check() {
    printf "Checking for %-20s" "$1 ..."
    if command -v "$2" >/dev/null 2>&1; then
        echo "  ok  ($(command -v "$2"))"
    else
        echo "  MISSING"
        echo "configure: error: '$2' not found. $3" >&2
        exit 1
    fi
}

check "C compiler"  "$CC"   "Install gcc or set CC= to your compiler."
check "make"        "make"  "Install GNU make."

# ---- Check for OpenSSL ---------------------------------------------
printf "Checking for %-20s" "openssl (libcrypto) ..."
tmpdir=$(mktemp -d)
cat > "$tmpdir/test.c" <<'EOF'
#include <openssl/evp.h>
int main(void) { EVP_MD_CTX_new(); return 0; }
EOF
if $CC ${CFLAGS:-} -o "$tmpdir/test" "$tmpdir/test.c" ${LDFLAGS:-} -lcrypto 2>/dev/null; then
    echo "  ok"
else
    echo "  MISSING"
    echo "configure: error: OpenSSL not found." >&2
    echo "  Ubuntu/Debian:  sudo apt-get install libssl-dev" >&2
    echo "  Fedora/RHEL:    sudo dnf install openssl-devel" >&2
    echo "  macOS:          brew install openssl" >&2
    echo "                  then re-run: CFLAGS=-I\$(brew --prefix openssl)/include \\" >&2
    echo "                               LDFLAGS=-L\$(brew --prefix openssl)/lib ./configure" >&2
    rm -rf "$tmpdir"
    exit 1
fi
rm -rf "$tmpdir"

# ---- Check compiler works ------------------------------------------
printf "Checking if %-20s" "$CC compiles ..."
tmpdir=$(mktemp -d)
cat > "$tmpdir/test.c" <<'EOF'
int main(void) { return 0; }
EOF
if $CC -o "$tmpdir/test" "$tmpdir/test.c" 2>/dev/null; then
    echo "  ok"
else
    echo "  FAILED"
    echo "configure: error: $CC cannot compile a simple program." >&2
    rm -rf "$tmpdir"
    exit 1
fi
rm -rf "$tmpdir"

# ---- Generate Makefile from Makefile.in ----------------------------
printf "Generating Makefile ..."
sed \
    -e "s|@CC@|$CC|g" \
    -e "s|@PREFIX@|$PREFIX|g" \
    -e "s|@VERSION@|$VERSION|g" \
    -e "s|@EXTRA_CFLAGS@|${CFLAGS:-}|g" \
    -e "s|@EXTRA_LDFLAGS@|${LDFLAGS:-}|g" \
    Makefile.in > Makefile
echo "  done"

# ---- Summary -------------------------------------------------------
cat <<EOF

Configuration summary:
  CC      = $CC
  PREFIX  = $PREFIX
  VERSION = $VERSION
  CFLAGS  = ${CFLAGS:-<none>}
  LDFLAGS = ${LDFLAGS:-<none>}

Build with:
  make
  sudo make install
EOF
